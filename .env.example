# Copy to .env and fill in your own values. Never commit .env.

# --- LLM server (server/ov_llm_server.py) ---
EDISPENSE_LLM_MODEL_DIR=models/qwen2.5-3b-int4-ov
EDISPENSE_LLM_DEVICE=GPU

# --- ASR server (server/asr_service.py) ---
EDISPENSE_ASR_MODEL_DIR=models/sensevoice

# --- Gateway: SSH tunnel to the RK3588 board (gateway/edispense_control.py) ---
EDISPENSE_BOARD_HOST=192.168.137.100
EDISPENSE_BOARD_PORT=22
EDISPENSE_BOARD_USER=root
EDISPENSE_BOARD_PWD=

# --- mDNS advertise (gateway/edispense_mdns.py); leave empty to auto-detect ---
EDISPENSE_HOST_IP=

# --- WiFi config agent (wifi/wifi_agent.py) ---
EDISPENSE_WIFI_BIND_IP=192.168.137.1

# --- Windows Mobile Hotspot (scripts/tether_start.ps1) ---
EDISPENSE_AP_SSID=EDispense-AP
EDISPENSE_AP_PASS=changeme12345
